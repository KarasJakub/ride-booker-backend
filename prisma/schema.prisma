generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  BRANCH_ADMIN
  USER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  website   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  locations Location[]
  users     User[]

  @@map("organizations")
}

// ─── Users ────────────────────────────────────────────────

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  fullName   String?  @map("full_name")
  phone      String?
  role       Role     @default(USER)
  isActive   Boolean  @default(true) @map("is_active")
  supabaseId String   @unique @map("supabase_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // ORG_ADMIN — należy do organizacji
  organizationId String?       @unique @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // BRANCH_ADMIN — zarządza lokalizacją
  managedLocation Location? @relation("BranchAdminLocation")

  bookings  Booking[]
  favorites Favorite[]

  @@map("users")
}

// ─── Locations (Branch) ───────────────────────────────────

model Location {
  id        String   @id @default(uuid())
  name      String
  city      String
  address   String?
  phone     String?
  lat       Float?
  lng       Float?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // należy do organizacji
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // BRANCH_ADMIN tej lokalizacji
  branchAdminId String? @unique @map("branch_admin_id")
  branchAdmin   User?   @relation("BranchAdminLocation", fields: [branchAdminId], references: [id], onDelete: SetNull)

  inventory LocationVehicle[]

  @@map("locations")
}

// ─── Vehicles ────────────────────────────────────────────

model VehicleType {
  id       String    @id @default(uuid())
  name     String    @unique
  vehicles Vehicle[]

  @@map("vehicle_types")
}

model Vehicle {
  id             String   @id @default(uuid())
  name           String
  engineCapacity Int?     @map("engine_capacity")
  power          Int?
  description    String?
  imageUrl       String?  @map("image_url")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  typeId String      @map("type_id")
  type   VehicleType @relation(fields: [typeId], references: [id])

  inventory LocationVehicle[]
  favorites Favorite[]

  @@map("vehicles")
}

// ─── Inventory (Location ↔ Vehicle) ──────────────────────

model LocationVehicle {
  id          String   @id @default(uuid())
  quantity    Int      @default(1)
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  locationId String   @map("location_id")
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  vehicleId String  @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  slots Slot[]

  @@unique([locationId, vehicleId])
  @@map("location_vehicles")
}

// ─── Slots ───────────────────────────────────────────────

model Slot {
  id          String   @id @default(uuid())
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  locationVehicleId String          @map("location_vehicle_id")
  locationVehicle   LocationVehicle @relation(fields: [locationVehicleId], references: [id], onDelete: Cascade)

  booking Booking?

  @@map("slots")
}

// ─── Bookings ─────────────────────────────────────────────

model Booking {
  id              String        @id @default(uuid())
  status          BookingStatus @default(PENDING)
  notes           String?
  rejectionReason String?       @map("rejection_reason")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  slotId String @unique @map("slot_id")
  slot   Slot   @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

// ─── Favorites ────────────────────────────────────────────

model Favorite {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  vehicleId String  @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([userId, vehicleId])
  @@map("favorites")
}
